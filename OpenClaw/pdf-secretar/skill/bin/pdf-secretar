#!/bin/bash
# pdf-secretar – universal skill script runner

VENV_PYTHON="$HOME/.openclaw/workspace/.venv/bin/python"
SCRIPTS_DIR="$HOME/.openclaw/skills/pdf-secretar/scripts"

if [ ! -f "$VENV_PYTHON" ]; then
echo "❌ Virtual environment not found in $VENV_PYTHON"
exit 1
fi

if [ $# -lt 1 ]; then
echo "Usage: pdf-secretar <command> [arguments...]"
echo "Available commands:"
ls -1 "$SCRIPTS_DIR" | sed 's/\.py$//' | column 
exit 1
fi

COMMAND="$1"
shift
SCRIPT="$SCRIPTS_DIR/${COMMAND}.py"

if [! -f "$SCRIPT" ]; then 
echo "❌ Command '$COMMAND' not found" 
exit 1
fi

exec "$VENV_PYTHON" "$SCRIPT" "$@"